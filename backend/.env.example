APP_NAME="Ledgr"
APP_VERSION="0.1.0"
DATABASE_URL="postgresql+asyncpg://ledgr:ledgr_dev_password@localhost:5433/ledgr"
LOG_LEVEL="INFO"

# Change this to a long random string for anything other than local dev.
JWT_SECRET_KEY="change-me"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15

# Mock processor success rate (0.0 - 1.0). Defaults to 0.9 if unset.
PROCESSOR_SUCCESS_RATE=0.9

# Comma-separated browser origins allowed to call the API (the frontend dev server).
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
